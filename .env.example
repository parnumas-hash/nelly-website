# Site URL (optional — defaults to Vercel URL or nellygroup.com)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin panel (/admin)
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SESSION_SECRET=random-long-secret-for-cookie-signing

# After deploying Supabase schema-admin-users.sql, login with:
# username: admin  password: ADMIN_PASSWORD (auto-created on first login)
